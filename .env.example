# FocusFlow local and Google Cloud environment template.
# Values below match the verified thesis project as of 2026-06-12.
# Secret payloads and resources that do not exist yet remain empty or documented.

# ----------------------------
# Desktop client -> Cloud API
# ----------------------------
# Read the payload from Secret Manager manually after deployment.
FOCUSFLOW_CLOUD_API_KEY=

# Cloud Run service is not deployed yet, so no URL is available.
FOCUSFLOW_CLOUD_API_URL=

# Leave blank to let the desktop generate and persist a stable ID.
FOCUSFLOW_DEVICE_ID=

# ----------------------------
# Local API runtime
# ----------------------------
FOCUSFLOW_ENV=development
FOCUSFLOW_API_KEY=
FOCUSFLOW_REPOSITORY=memory
FOCUSFLOW_EVENT_BACKEND=logging
FOCUSFLOW_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PORT=8080

# ----------------------------
# Verified Google Cloud project
# ----------------------------
GOOGLE_CLOUD_PROJECT=my-thesis-496702
FOCUSFLOW_GCP_PROJECT_NUMBER=1093941638042
FOCUSFLOW_GCP_REGION=asia-southeast1
FOCUSFLOW_CLOUD_BUILD_SERVICE_ACCOUNT=1093941638042-compute@developer.gserviceaccount.com

# Firestore
FOCUSFLOW_FIRESTORE_DATABASE=(default)
FOCUSFLOW_FIRESTORE_LOCATION=asia-southeast1
FOCUSFLOW_FIRESTORE_SESSIONS_COLLECTION=focusflow_sessions

# Pub/Sub
FOCUSFLOW_PUBSUB_SESSION_EVENTS_TOPIC=focusflow-session-events
FOCUSFLOW_PUBSUB_SESSION_EVENTS_TOPIC_PATH=projects/my-thesis-496702/topics/focusflow-session-events

# Artifact Registry
FOCUSFLOW_ARTIFACT_REPOSITORY=focusflow
FOCUSFLOW_ARTIFACT_REGISTRY_URI=asia-southeast1-docker.pkg.dev/my-thesis-496702/focusflow

# Cloud Run service and dedicated service account do not exist yet.
FOCUSFLOW_CLOUD_RUN_SERVICE=focusflow-api
FOCUSFLOW_CLOUD_RUN_SERVICE_ACCOUNT=focusflow-api@my-thesis-496702.iam.gserviceaccount.com

# Secret Manager metadata only. Never commit the secret payload.
FOCUSFLOW_API_KEY_SECRET=focusflow-api-key
FOCUSFLOW_API_KEY_SECRET_VERSION=1
FOCUSFLOW_API_KEY_SECRET_RESOURCE=projects/1093941638042/secrets/focusflow-api-key/versions/1
